# App
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_URL=http://localhost:5177

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/procureflow
TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/procureflow_test

# JWT / Security
SECRET_KEY=change-this-in-real-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email / SMTP
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# Seed users
SEED_ADMIN_EMAIL=admin@procureflow.dev
SEED_ADMIN_PASSWORD=ChangeMe_Admin_123!
SEED_OTHER_EMAIL=other@procureflow.dev
SEED_OTHER_PASSWORD=ChangeMe_Other_123!
